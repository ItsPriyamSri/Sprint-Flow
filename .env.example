# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT TARGETS
# ─────────────────────────────────────────────────────────────
# Vercel (web):   set NEXT_PUBLIC_API_URL in Vercel project env vars.
#                 All other vars below are API-only and not needed on Vercel.
#
# Railway (API):  set all vars below in your Railway service env vars.
#                 railway.toml at repo root points Railway to docker/Dockerfile.api.
#                 Database: use Railway's Postgres plugin or Neon.tech.
#
# AWS ECS (future): vars marked "AWS Secrets Manager" move to Secrets Manager.
#                   .github/workflows/deploy.yml activates when vars.AWS_REGION is set.
# ═══════════════════════════════════════════════════════════════

# ─── Database ───────────────────────────────────────────────
# Local dev: `docker compose -f docker-compose.dev.yml up -d` maps Postgres to host port 5433.
# Railway:   paste the Railway Postgres / Neon connection string here.
# AWS:       set via Secrets Manager; include connection_limit=5 for RDS pool sizing.
#   e.g. postgresql://user:pass@host:5432/sprintflow?schema=public&connection_limit=5
DATABASE_URL="postgresql://sprintflow:sprintflow@localhost:5433/sprintflow?schema=public"

# ─── JWT ────────────────────────────────────────────────────
# Production: set via AWS Secrets Manager. Use strong random values ≥32 chars.
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── API Server ──────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ─── Rate limiting ───────────────────────────────────────────
# Per-IP limits. Defaults shown match production hardening.
# For a LOAD TEST from a single machine, temporarily raise these (e.g. on Railway),
# run the test, then revert — otherwise the limiter returns 429 and you measure it, not the app.
RATE_LIMIT_WINDOW_MS=900000        # 15 min
RATE_LIMIT_MAX=500                 # max requests per window per IP (load test: e.g. 2000000)
LOGIN_RATE_LIMIT_WINDOW_MS=60000   # 1 min
LOGIN_RATE_LIMIT_MAX=10            # max login attempts per window per IP (load test: e.g. 100000)

# ─── CORS ────────────────────────────────────────────────────
# Required in production — startup fails if unset when NODE_ENV=production.
# Comma-separated for multiple origins: https://app.company.com,https://www.company.com
CORS_ORIGIN="http://localhost:3002"

# ─── File Storage ────────────────────────────────────────────
# "local"  — writes to STORAGE_LOCAL_DIR on disk (dev / Railway with a mounted volume).
# "s3"     — S3-compatible storage; credentials via env vars (Railway) or task role (AWS ECS).
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"
STORAGE_MAX_FILE_SIZE_MB=20

# ─── S3 (required when STORAGE_DRIVER=s3) ───────────────────
# Railway: set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY env vars alongside these.
# AWS ECS: omit the key env vars — the ECS task role provides credentials automatically.
#   Task role needs: s3:PutObject, s3:GetObject, s3:DeleteObject on arn:aws:s3:::<bucket>/*
# Cloudflare R2 is a cost-effective alternative (S3-compatible, no egress fees):
#   Set endpoint via AWS_ENDPOINT_URL_S3 if using R2 or another S3-compatible provider.
S3_BUCKET="sprintflow-uploads-prod"
S3_REGION="ap-south-1"
# AWS_ACCESS_KEY_ID=     # Railway / non-ECS only; leave unset on AWS ECS
# AWS_SECRET_ACCESS_KEY= # Railway / non-ECS only; leave unset on AWS ECS

# ─── Web (Next.js) ───────────────────────────────────────────
# Baked into the Next.js bundle at build time — set in the build environment, not at runtime.
# Vercel:  add NEXT_PUBLIC_API_URL as an environment variable in your Vercel project settings.
# Docker:  pass as --build-arg NEXT_PUBLIC_API_URL=... to docker build (see Dockerfile.web).
# AWS ECS: pass as vars.NEXT_PUBLIC_API_URL in GitHub Actions (see deploy.yml).
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
WEB_PORT=3002

# ─── Seed (legacy — until RBAC migration; maps to SUPER_ADMIN in seed) ───────
# In production: seed refuses to run unless SEED_ADMIN_PASSWORD is explicitly set
# and passes strength checks (≥12 chars, not a known weak value).
# Copy to .env and set passwords locally — do not commit .env.
SEED_ADMIN_EMAIL="priyam.srivastava@geti.education"
SEED_ADMIN_PASSWORD="your-super-admin-password"
SEED_ADMIN_NAME="Priyam"
SEED_WORKSPACE_NAME="GETI Workspace"

# ─── Auth / RBAC ─────────────────────────────────────────────────────────────
# Only @geti.education emails may sign in (comma-separated for multiple domains).
ALLOWED_EMAIL_DOMAINS="geti.education"

# Password assigned to new members added by a team lead or super admin.
# They are forced to change it on first login (mustChangePassword = true).
# Set a strong value in production; share out-of-band with new members.
DEFAULT_MEMBER_PASSWORD="your-default-member-password"

# Comma-separated list of emails that get SUPER_ADMIN role on first JIT login
# (or when re-seeding). All must be @geti.education addresses.
SUPER_ADMIN_EMAILS="priyam.srivastava@geti.education"

# Password for the primary super admin created during seeding.
SEED_SUPER_ADMIN_PASSWORD="your-super-admin-password"

# ─── Deprecated (no longer used) ─────────────────────────────────────────────
# These were used when new users were auto-joined to a single default workspace.
# Team assignment is now managed explicitly — users get no workspace until a
# team lead or super admin adds them to a team.
# DEFAULT_WORKSPACE_SLUG=   # removed — no longer auto-joined on login
# DEFAULT_PROJECT_ID=       # removed — no longer auto-joined on login
