# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://sprintflow:sprintflow@localhost:5432/sprintflow?schema=public"

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── API Server ──────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:3000"

# ─── File Storage ────────────────────────────────────────────
# "local" for MVP; swap to "s3" later without code changes
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"
STORAGE_MAX_FILE_SIZE_MB=20

# ─── Web (Next.js) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
WEB_PORT=3000

# ─── Seed ────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@sprintflow.local"
SEED_ADMIN_PASSWORD="Admin1234!"
SEED_ADMIN_NAME="Admin"
SEED_WORKSPACE_NAME="My Workspace"
