# ─── Database ───────────────────────────────────────────────
# Local dev: `docker compose -f docker-compose.dev.yml up -d` maps Postgres to host port 5433.
# Production Docker Compose: API uses postgres:5432 inside the compose network (see docker-compose.yml).
DATABASE_URL="postgresql://sprintflow:sprintflow@localhost:5433/sprintflow?schema=public"

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── API Server ──────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────
# Must match the web app origin. Local dev uses port 3002; Docker Compose web container uses 3000.
CORS_ORIGIN="http://localhost:3002"

# ─── File Storage ────────────────────────────────────────────
# "local" for MVP; swap to "s3" later without code changes
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage"
STORAGE_MAX_FILE_SIZE_MB=20

# ─── Web (Next.js) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
WEB_PORT=3002

# ─── Seed ────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@sprintflow.local"
SEED_ADMIN_PASSWORD="Admin1234!"
SEED_ADMIN_NAME="Admin"
SEED_WORKSPACE_NAME="My Workspace"
